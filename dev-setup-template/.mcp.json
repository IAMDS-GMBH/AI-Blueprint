{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "description": "Aktuelle Library-Dokumentation — kein veraltetes Halluzinieren"
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-playwright@latest"],
      "description": "Browser-Automatisierung und E2E-Testing via Playwright"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-github@latest"],
      "description": "GitHub Issues, PRs, Repos direkt aus dem AI-Tool verwalten"
    }
  }
}
