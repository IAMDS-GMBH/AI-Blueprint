{
  "servers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "description": "Aktuelle Library-Dokumentation"
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-playwright@latest"],
      "description": "Browser-Automatisierung und E2E-Testing via Playwright"
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-github@latest"],
      "description": "GitHub Issues, PRs, Repos direkt aus Copilot verwalten"
    }
  }
}
