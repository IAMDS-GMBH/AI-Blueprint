{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(mvn *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(docker *)",
      "Bash(flyway *)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
